<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.0.xsd">


    <changeSet id="1" author="darkvelton">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(30)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="middle_name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="age" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(60)">
                <constraints nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <createTable tableName="departments">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
        </createTable>

    </changeSet>
    <changeSet id="2" author="darkvelton">
        <createTable tableName="doctors">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="cabinet" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="job_title" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="department_id" type="BIGINT">
                <constraints
                        nullable="false"
                        foreignKeyName="fk_doctor_department"
                        referencedTableName="departments"
                        referencedColumnNames="id"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints
                        nullable="false"
                        unique="true"
                        foreignKeyName="fk_doctor_user"
                        referencedTableName="users"
                        referencedColumnNames="id"/>
            </column>
        </createTable>


        <createTable tableName="clients">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints
                        nullable="false"
                        unique="true"
                        foreignKeyName="fk_client_user"
                        referencedTableName="users"
                        referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="3" author="darkvelton">

        <createTable tableName="passports">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="issued_by" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="issued_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="number" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="series" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"
                             unique="true"
                             foreignKeyName="fk_passport_user"
                             referencedTableName="users"
                             referencedColumnNames="id"
                />
            </column>
        </createTable>
        <createTable tableName="medical_records">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="blood_type" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="rh_factor" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="allergies" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="chronic_diseases" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="family_history" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="insurance_number" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="update_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints
                        nullable="false"
                        unique="true"
                        foreignKeyName="fk_medical_record_client"
                        referencedTableName="clients"
                        referencedColumnNames="id"/>
            </column>
        </createTable>

    </changeSet>
    <changeSet id="4" author="darkvelton">

        <createTable tableName="bookings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="condition" type="VARCHAR(30)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_booking_client"
                             referencedTableName="clients"
                             referencedColumnNames="id"/>

            </column>
            <column name="doctor_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_booking_doctor"
                             referencedTableName="doctors"
                             referencedColumnNames="id"/>
            </column>
        </createTable>

    </changeSet>
    <changeSet id="5" author="darkvelton">
        <createSequence sequenceName="bookings_seq" startValue="1" incrementBy="50"/>
        <createSequence sequenceName="clients_seq" startValue="1" incrementBy="50"/>
        <createSequence sequenceName="passport_seq" startValue="1" incrementBy="50"/>
        <createSequence sequenceName="doctors_seq" startValue="1" incrementBy="50"/>
        <createSequence sequenceName="medical_records_seq" startValue="1" incrementBy="50"/>
        <createSequence sequenceName="users_seq" startValue="1" incrementBy="50"/>
    </changeSet>


</databaseChangeLog>